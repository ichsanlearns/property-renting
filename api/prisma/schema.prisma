generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String                                 @id @default(uuid())
  email             String                                 @unique 
  phoneNumber       String?       @map("phone_number")

  firstName         String?       @map("first_name")
  lastName          String?      @map("last_name")
  
  password          String?   
  profileImage      String?      @map("profile_image")
  profileImagePublicId     String?      @map("profile_image_public_id")    

  role              Role?   

  isVerified        Boolean      @map("is_verified")       @default(false) 
  referralCode      String?       @map("referral_code")     @unique 

  createdAt         DateTime     @map("created_at")        @default(now())         
  updatedAt         DateTime     @map("updated_at")        @updatedAt
  deletedAt         DateTime?    @map("deleted_at")

  refreshTokens RefreshToken[] 
  properties     Property[]
  reviews        Review[]
  reservations   Reservation[]
  
  points Point[]
  coupons Coupon[]
  accounts Account[]
  pricingRules PricingRule[]


  @@map("users")
}

model Account {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  provider          String
  providerAccountId String    @map("provider_account_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model RegisterToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([email])
  @@map("register_tokens")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  hashedToken String    @unique @map("hashed_token")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Property {
  id                String             @id @default(uuid())
  tenantId          String             @map("tenant_id")
  categoryId        String             @map("category_id")

  name              String
  description       String

  city              String
  province          String
  country           String

  latitude          Float
  longitude         Float
  
  fullAddress       String             @map("full_address")
  numberOfBathrooms Int                @map("number_of_bathrooms")

  averageRating     Decimal?           @map("average_rating") @db.Decimal(2, 1)
  reviewCount       Int                @default(0) @map("review_count")

  roomAvailable     Int                @default(0) @map("room_available")
  minPrice          Decimal?            @db.Decimal(10, 2) @map("min_price")

  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")


  isPublished       PublishStatus      @default(DRAFT) @map("is_published")
  isVerified        VerificationStatus @default(PENDING) @map("is_verified")
  
  

  category          PropertyCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenant            User               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  pricingRules      PricingRule[]
  propertyAmenities PropertyAmenity[]
  propertyImages    PropertyImage[]
  reviews           Review[]
  roomTypes         RoomType[]
  voucher           Voucher[]

  @@index([city])
  @@index([categoryId])
  @@map("properties")
}

model PropertyCategory {
  id         String     @id @default(uuid())
  name       String
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  deletedAt  DateTime?  @map("deleted_at")
  properties Property[]

  @@map("property_categories")
}

model Amenity {
  id                String            @id @default(uuid())
  name              String
  icon              String
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")
  type              AmenityType
  description       String?
  propertyAmenities PropertyAmenity[]
  roomAmenities     RoomTypeAmenity[]

  @@map("amenities")
}

model PropertyAmenity {
  id         String    @id @default(uuid())
  propertyId String    @map("property_id")
  amenityId  String    @map("amenity_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  amenity    Amenity   @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, amenityId])
  @@map("property_amenities")
}

model PropertyImage {
  id                String                                   @id @default(uuid())
  propertyId        String     @map("property_id")

  imageUrl          String?     @map("image_url")
  imagePublicId     String?     @map("image_public_id")
  
  isCover           Boolean    @map("is_cover")            @default(false)
  order             Int        @default(0)

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)


  @@map("property_images")
}

model RoomType {
  id             String             @id @default(uuid())
  propertyId     String             @map("property_id")
  name           String
  capacity       Int
  basePrice      Decimal            @map("base_price") @db.Decimal(10, 2)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")
  isPublished    PublishStatus      @default(DRAFT) @map("is_published")
  isVerified     VerificationStatus @default(PENDING) @map("is_verified")
  bathroomType   BathroomType       @map("bathroom_type")
  bedCount       Int                @map("bed_count")
  bedType        BedType            @map("bed_type")
  viewType       ViewType           @map("view_type")
  totalRooms     Int                @map("total_rooms")
  averageRating  Decimal?           @map("average_rating") @db.Decimal(2, 1)
  reviewCount    Int                @default(0) @map("review_count")
  availableRooms Int                @map("available_rooms")
  priceOverrides PriceOverride[]
  pricingRules   PricingRule[]
  reservations   Reservation[]
  roomAmenities  RoomTypeAmenity[]
  roomTypeImages RoomTypeImage[]
  roomTypePrices RoomTypePrice[]
  property       Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("room_types")
}

model RoomTypeAmenity {
  id         String    @id @default(uuid())
  roomTypeId String    @map("room_type_id")
  amenityId  String    @map("amenity_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  amenity    Amenity   @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  roomType   RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, amenityId])
  @@map("room_type_amenities")
}

model RoomTypeImage {
  id                String                                   @id @default(uuid())
  roomTypeId        String     @map("room_type_id")

  imageUrl          String?     @map("image_url")
  imagePublicId     String?     @map("image_public_id")
  
  isCover           Boolean    @map("is_cover")            @default(false)
  order             Int        @default(0)

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)


  @@map("room_type_images")
}

model RoomTypePrice {
  id                   String       @id @default(uuid())
  roomTypeId           String       @map("room_type_id")
  date                 DateTime     @db.Date
  price                Decimal      @db.Decimal(10, 2)
  availableRooms       Int          @map("available_rooms")
  isClosed             Boolean      @default(false) @map("is_closed")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  deletedAt            DateTime?    @map("deleted_at")
  appliedPricingRuleId String?      @map("applied_pricing_rule_id")
  appliedPricingRule   PricingRule? @relation(fields: [appliedPricingRuleId], references: [id], onDelete: Cascade)
  roomType             RoomType     @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, date])
  @@index([roomTypeId, date])
  @@map("room_type_prices")
}

model PriceOverride {
  id         String   @id @default(uuid())
  roomTypeId String   @map("room_type_id")
  date       DateTime
  price      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, date])
  @@map("price_overrides")
}

model PricingRule {
  id                  String                   @id @default(cuid())
  adjustmentType      PriceAdjustmentType      @map("adjustment_type")
  isActive            Boolean                  @default(true) @map("is_active")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  adjustmentValue     Decimal                  @db.Decimal(10, 2)
  adjustmentDirection PriceAdjustmentDirection @map("adjustment_direction")
  createdBy           String                   @map("created_by")
  endDate             DateTime                 @map("end_date") @db.Date
  name                String?
  priority            Int                      @default(0)
  propertyId          String?                  @map("property_id")
  roomTypeId          String?                  @map("room_type_id")
  scopeType           ScopeType                @map("scope_type")
  startDate           DateTime                 @map("start_date") @db.Date
  tenantId            String?                  @map("tenant_id")
  daysOfWeek          Int[]                    @map("days_of_week")
  property            Property?                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomType            RoomType?                @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  tenant              User?                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomTypePrices      RoomTypePrice[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomTypeId])
  @@index([startDate, endDate])
  @@index([tenantId, scopeType])
  @@index([tenantId, propertyId])
  @@index([tenantId, roomTypeId])
  @@map("pricing_rules")
}

model Reservation {
  id                          String            @id @default(uuid())
  customerId                  String            @map("customer_id")
  roomTypeId                  String            @map("room_type_id")
  couponId                    String?           @map("coupon_id")
  voucherId                   String?           @map("voucher_id")
  checkInDate                 DateTime          @map("check_in_date") @db.Date
  checkOutDate                DateTime          @map("check_out_date") @db.Date
  guestCount                  Int?              @map("guest_count")
  usingPoints                 Decimal?          @default(0) @map("using_points") @db.Decimal(10, 2)
  totalAmount                 Decimal           @map("total_amount") @db.Decimal(10, 2)
  status                      ReservationStatus
  paymentDeadline             DateTime          @map("payment_deadline")
  createdAt                   DateTime          @default(now()) @map("created_at")
  updatedAt                   DateTime          @updatedAt @map("updated_at")
  deletedAt                   DateTime?         @map("deleted_at")
  paymentProof                String?           @map("payment_proof")
  averageRoomPerNightSnapshot Decimal           @map("average_room_per_night_snapshot") @db.Decimal(10, 2)
  numberOfNights              Int               @map("number_of_nights")
  propertyNameSnapshot        String            @map("property_name_snapshot")
  reservationCode             String            @unique @map("reservation_code")
  roomNameSnapshot            String            @map("room_name_snapshot")
  rejectionReason             String?           @map("rejection_reason")
  payments                    Payment[]
  customer                    User              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  roomType                    RoomType          @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  voucher                     Voucher?          @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  reviews                     Review?

  @@index([customerId])
  @@index([roomTypeId])
  @@index([status])
  @@map("reservations")
}

model Payment {
  id            String        @id @default(uuid())
  reservationId String        @map("reservation_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @map("payment_status")
  transactionId String        @map("transaction_id")
  proofImage    String?       @map("proof_image")
  confirmedAt   DateTime?     @map("confirmed_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("payments")
}


model Review {
  id            String      @id @default(uuid())
  reservationId String      @unique @map("reservation_id")
  customerId    String      @map("customer_id")
  propertyId    String      @map("property_id")
  rating        Int
  comment       String
  tenantReply String?   @map("tenant_reply")
  repliedAt   DateTime? @map("replied_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  customer      User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  property      Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Point {
  id        String    @id @default(uuid())
  userId    String    @unique @map("user_id")
  amount    Decimal   @db.Decimal(10, 2)
  expiredAt DateTime  @map("expired_at")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("points")
}

model Voucher {
  id                  String        @id @default(uuid())
  propertyId          String        @map("property_id")
  code                String        @unique
  discountAmount      Decimal       @map("discount_amount") @db.Decimal(10, 2)
  quota               Int
  startDate           DateTime      @map("start_date")
  endDate             DateTime      @map("end_date")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  deletedAt           DateTime?     @map("deleted_at")
  PropertyReservation Reservation[]
  Properties          Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("vouchers")
}

model Coupon {
  id             String    @id @default(uuid())
  customerId     String    @map("customer_id")
  discountAmount Decimal   @map("discount_amount") @db.Decimal(10, 2)
  referrerId     String    @map("referrer_id")
  expiredAt      DateTime  @map("expired_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  customer       User      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("coupons")
}

enum Role {
  CUSTOMER
  TENANT
}

enum PaymentMethod {
  MANUAL_TRANSFER
  E_WALLET
  CREDIT_CARD
}

enum PaymentStatus {
  WAITING_CONFIRMATION
  APPROVED
  REJECTED
}

enum ReservationStatus {
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  REJECTED
  EXPIRED
  CANCELED
  PAID
  REVIEWED
}

enum PriceAdjustmentType {
  NOMINAL
  PERCENTAGE
}

enum PriceAdjustmentDirection {
  DECREASE
  INCREASE
}

enum ScopeType {
  SYSTEM
  TENANT
  PROPERTY
  ROOM_TYPE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AmenityType {
  PROPERTY
  ROOM
}

enum BathroomType {
  PRIVATE
  SHARED
}

enum BedType {
  KING_SIZE
  QUEEN_SIZE
  DOUBLE_TWIN
  SINGLE
}

enum ViewType {
  OCEAN_FRONT
  GARDEN_VIEW
  CITY_SKYLINE
  POOL_SIDE
  NONE
}

enum TokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
  REGISTER
}
