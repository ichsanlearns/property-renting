// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  TENANT
}

enum PaymentMethod {
  MANUAL_TRANSFER
  E_WALLET
  CREDIT_CARD
}

enum PaymentStatus {
  WAITING_CONFIRMATION
  APPROVED
  REJECTED
}

enum ReservationStatus {
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  REJECTED
  EXPIRED
  CANCELED
  PAID
  REVIEWED
}

enum PriceAdjustmentType {
  NOMINAL
  PERCENTAGE
}

enum PriceAdjustmentDirection {
  MINUS
  PLUS
}

enum ScopeType {
  SYSTEM
  TENANT
  PROPERTY
  ROOM_TYPE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AmenityType {
  PROPERTY
  ROOM
}

enum BathroomType {
  PRIVATE
  SHARED
}

enum BedType {
  KING_SIZE
  QUEEN_SIZE
  DOUBLE_TWIN
  SINGLE
}

enum ViewType {
  OCEAN_FRONT
  GARDEN_VIEW
  CITY_SKYLINE
  POOL_SIDE
  NONE
}

enum TokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
  REGISTER
}

model User {
  id                String                                 @id @default(uuid())
  email             String                                 @unique 
  phoneNumber       String?       @map("phone_number")

  firstName         String?       @map("first_name")
  lastName          String?      @map("last_name")
  
  password          String?       
  profileImage      String?      @map("profile_image")
  role              Role?   

  isVerified        Boolean      @map("is_verified")       @default(false) 
  referralCode      String?       @map("referral_code")     @unique 

  createdAt         DateTime     @map("created_at")        @default(now())         
  updatedAt         DateTime     @map("updated_at")        @updatedAt
  deletedAt         DateTime?    @map("deleted_at")

  refreshTokens RefreshToken[] 
  properties     Property[]
  reviews        Review[]
  reservations   Reservation[]
  
  points Point[]
  coupons Coupon[]
  accounts Account[]
  pricingRules PricingRule[]

  @@map("users")
}

model Account {
  id                String                                @id @default(uuid())
  userId            String       @map("user_id")

  provider          String
  providerAccountId String       @map("provider_account_id")
  
  createdAt         DateTime     @map("created_at")       @default(now())         
  updatedAt         DateTime     @map("updated_at")        @updatedAt
  deletedAt         DateTime?    @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model RegisterToken {
  id                String                                @id @default(uuid())
  email             String       

  token             String                                @unique 
  type              TokenType  

  expiresAt         DateTime     @map("expires_at")

  createdAt         DateTime     @map("created_at")       @default(now())         
  deletedAt         DateTime?    @map("deleted_at")

  @@index([email])

  @@map("register_tokens")
}

model RefreshToken {
  id                String                                @id @default(uuid())
  hashedToken       String       @map("hashed_token")     @unique 
  userId            String       @map("user_id")
  expiresAt         DateTime     @map("expires_at")
  createdAt         DateTime     @map("created_at")       @default(now())         
  deletedAt         DateTime?    @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model Property {
  id                 String                                @id @default(uuid())
  tenantId           String    @map("tenant_id")
  categoryId         String    @map("category_id")
  
  name              String    
  description        String    

  country            String    
  city               String 
  province           String
  fullAddress        String    @map("full_address")

  latitude           Float
  longitude          Float

  numberOfBathrooms Int        @map("number_of_bathrooms")

  averageRating     Decimal?     @map("average_rating")      @db.Decimal(1,1)
  reviewCount       Int        @map("review_count")          @default(0)

  isVerified        VerificationStatus    @map("is_verified")           @default(PENDING)
  isPublished       PublishStatus    @map("is_published")          @default(DRAFT)

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  tenant User @relation(fields: [tenantId], references: [id])
  category PropertyCategory @relation(fields: [categoryId], references: [id])

  propertyAmenities PropertyAmenity[]
  propertyImages    PropertyImage[]
  roomTypes         RoomType[]
  reviews            Review[]
  voucher            Voucher[]
  pricingRules       PricingRule[]

  @@index([city])
  @@index([categoryId])

  @@map("properties")
}

model PropertyCategory {
  id                String                                   @id @default(uuid())
  name              String

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  properties Property[]

  @@map("property_categories")
}

model Amenity {
  id                String                                   @id @default(uuid())
  name              String
  icon              String
  description       String?
  type              AmenityType

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  propertyAmenities PropertyAmenity[]
  roomAmenities     RoomTypeAmenity[]

  @@map("amenities")
}

model PropertyAmenity {
  id                String                                   @id @default(uuid())
  propertyId        String     @map("property_id")
  amenityId         String     @map("amenity_id")
  
  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  property Property @relation(fields: [propertyId], references: [id])
  amenity  Amenity  @relation(fields: [amenityId], references: [id])

  @@unique([propertyId, amenityId])

  @@map("property_amenities")
}

model PropertyImage {
  id                String                                   @id @default(uuid())
  propertyId        String     @map("property_id")

  imageUrl          String     @map("image_url")
  isCover           Boolean    @map("is_cover")            @default(false)
  order             Int        @default(0)

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@map("property_images")
}

model RoomType {
  id                String                                   @id @default(uuid())
  propertyId        String     @map("property_id")

  name              String
  description       String
  basePrice         Decimal    @map("base_price")            @db.Decimal(10,2) 
  totalRooms        Int        @map("total_rooms")

  bedType           BedType    @map("bed_type")
  bedCount          Int        @map("bed_count")
  viewType          ViewType   @map("view_type")
  bathroomType      BathroomType     @map("bathroom_type")
  capacity          Int

  isVerified        VerificationStatus    @map("is_verified")           @default(PENDING)
  isPublished       PublishStatus    @map("is_published")          @default(DRAFT)

  averageRating     Decimal?     @map("average_rating")      @db.Decimal(1,1)
  reviewCount       Int        @map("review_count")          @default(0)

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  property Property @relation(fields: [propertyId], references: [id])

  reservations      Reservation[]
  roomTypeImages  RoomTypeImage[]
  roomAmenities    RoomTypeAmenity[]
  roomTypePrices   RoomTypePrice[]
  priceOverrides   PriceOverride[]
  pricingRules       PricingRule[]

  @@map("room_types")
}

model RoomTypeAmenity {
  id                String                                   @id @default(uuid())
  roomTypeId        String     @map("room_type_id")
  amenityId         String     @map("amenity_id")

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  amenity  Amenity  @relation(fields: [amenityId], references: [id])

  @@unique([roomTypeId, amenityId])

  @@map("room_type_amenities")
}

model RoomTypeImage {
  id                String                                   @id @default(uuid())
  roomTypeId        String     @map("room_type_id")

  imageUrl          String     @map("image_url")
  isCover           Boolean    @map("is_cover")            @default(false)
  order             Int        @default(0)

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@map("room_type_images")
}

model RoomTypePrice {
  id              String                              @id @default(uuid())
  roomTypeId      String     @map("room_type_id")
  date            DateTime                            @db.Date
  price           Decimal    @db.Decimal(10,2)
  availableRooms  Int        @map("available_rooms")
  isClosed        Boolean    @map("is_closed")        @default(false)

  createdAt         DateTime   @map("created_at")            @default(now()) 
  updatedAt         DateTime   @map("updated_at")            @updatedAt
  deletedAt         DateTime?  @map("deleted_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@index([roomTypeId, date])

  @@unique([roomTypeId, date])

  @@map("room_type_prices")
}

model PriceOverride {
  id          String                              @id @default(uuid())
  roomTypeId  String     @map("room_type_id")
  date        DateTime
  price       Decimal    @db.Decimal(10,2)

  createdAt   DateTime   @map("created_at")            @default(now()) 
  updatedAt   DateTime   @map("updated_at")            @updatedAt

  roomType    RoomType  @relation(fields: [roomTypeId], references: [id])

  @@unique([roomTypeId, date])

  @@map("price_overrides")
}

model PricingRule {
  id              String   @id @default(cuid())

  scopeType       ScopeType @map("scope_type")
  tenantId        String @map("tenant_id")
  propertyId      String? @map("property_id")
  roomTypeId      String? @map("room_type_id")

  startDate       DateTime @map("start_date") 
  endDate         DateTime @map("end_date")

  dayOfWeek       Int[] @map("day_of_week")

  adjustmentType  PriceAdjustmentType @map("adjustment_type")
  adjustmentDirection PriceAdjustmentDirection @map("adjustment_direction")
  adjustmentValue           Decimal  @db.Decimal(10,2)

  priority        Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")

  name            String?
  createdBy       String   @map("created_by")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomTypeId])
  @@index([startDate, endDate])
  @@index([tenantId, scopeType])
  @@index([tenantId, propertyId])
  @@index([tenantId, roomTypeId])

  tenant User @relation(fields: [tenantId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])
  roomType RoomType? @relation(fields: [roomTypeId], references: [id])

  @@map("pricing_rules")
}



model Reservation {
  id                 String                               @id @default(uuid())
  customerId         String    @map("customer_id")
  roomTypeId         String    @map("room_type_id")
  couponId           String?   @map("coupon_id")
  voucherId          String?   @map("voucher_id")

  reservationCode    String    @map("reservation_code") @unique

  checkInDate        DateTime  @map("check_in_date") @db.Date
  checkOutDate       DateTime  @map("check_out_date") @db.Date
  numberOfNights     Int       @map("number_of_nights")

  guestCount         Int?       @map("guest_count")

  usingPoints        Decimal?   @map("using_points")       @db.Decimal(10,2) @default(0)
  totalAmount        Decimal   @map("total_amount")       @db.Decimal(10,2)
  status             ReservationStatus

  paymentDeadline    DateTime  @map("payment_deadline")
  paymentProof       String?   @map("payment_proof")
  rejectionReason    String?   @map("rejection_reason")
  
  roomNameSnapshot   String    @map("room_name_snapshot")
  propertyNameSnapshot String    @map("property_name_snapshot")
  averageRoomPerNightSnapshot Decimal    @map("average_room_per_night_snapshot") @db.Decimal(10,2)

  createdAt          DateTime  @map("created_at")         @default(now()) 
  updatedAt          DateTime  @map("updated_at")         @updatedAt
  deletedAt          DateTime? @map("deleted_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  customer  User     @relation(fields: [customerId], references: [id])

  voucher Voucher? @relation(fields: [voucherId], references: [id])

  payments  Payment[]
  reviews   Review[]

  @@index([customerId])
  @@index([roomTypeId])
  @@index([status])

  @@map("reservations")
}

model Payment {
  id                 String                                     @id @default(uuid())
  reservationId      String        @map("reservation_id")

  amount             Decimal                                    @db.Decimal(10,2)
  paymentMethod      PaymentMethod @map("payment_method")
  paymentStatus      PaymentStatus @map("payment_status")
  transactionId      String        @map("transaction_id")
  proofImage         String?       @map("proof_image")

  confirmedAt        DateTime?     @map("confirmed_at")

  createdAt          DateTime      @map("created_at")           @default(now()) 
  updatedAt          DateTime      @map("updated_at")           @updatedAt
  deletedAt          DateTime?     @map("deleted_at")

  reservation Reservation @relation(fields: [reservationId], references: [id])

  @@map("payments")
}

model Review {
  id                 String                                 @id @default(uuid())
  reservationId      String    @map("reservation_id")       @unique 
  customerId         String    @map("customer_id")
  propertyId         String    @map("property_id")

  rating             Int
  comment            String

  createdAt          DateTime  @map("created_at")           @default(now()) 
  updatedAt          DateTime  @map("updated_at")           @updatedAt
  deletedAt          DateTime? @map("deleted_at")

  reservation Reservation @relation(fields: [reservationId], references: [id])
  customer    User        @relation(fields: [customerId], references: [id])
  property    Property    @relation(fields: [propertyId], references: [id])

  @@map("reviews")
}

model Point {
  id         String                                 @id @default(uuid())
  userId     String                                 @unique @map("user_id")
  amount     Decimal                                @db.Decimal(10,2)

  expiredAt  DateTime  @map("expired_at")

  createdAt  DateTime  @map("created_at")           @default(now()) 
  deletedAt  DateTime? @map("deleted_at")
  updatedAt  DateTime  @map("updated_at")           @updatedAt

  User       User      @relation(fields: [userId], references: [id])

  @@map("points")
}

model Voucher {
  id              String                                 @id @default(uuid())
  propertyId      String    @map("property_id")
  code            String                                 @unique
  discountAmount  Decimal   @map("discount_amount")      @db.Decimal(10,2)      
  quota           Int

  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  createdAt       DateTime  @map("created_at")           @default(now()) 
  updatedAt       DateTime  @map("updated_at")           @updatedAt
  deletedAt       DateTime? @map("deleted_at")

  Properties Property @relation(fields: [propertyId], references: [id])

  PropertyReservation Reservation[]

  @@map("vouchers")
}

model Coupon {
  id                String                                 @id @default(uuid())
  customerId        String    @map("customer_id")
  
  discountAmount    Decimal   @map("discount_amount")      @db.Decimal(10,2) 
  referrerId        String    @map("referrer_id")
  
  expiredAt         DateTime  @map("expired_at")
  createdAt         DateTime  @map("created_at")           @default(now()) 
  updatedAt         DateTime  @map("updated_at")           @updatedAt
  deletedAt         DateTime? @map("deleted_at")

  customer User @relation(fields: [customerId], references: [id])

  @@map("coupons")
}